# Telegram bots. Add as many as you want; each one is independent.
# To set up:
#   1. Create a bot via @BotFather on Telegram → get a token
#   2. Start a DM with your bot (send /start)
#   3. Run: python src/telegram_setup.py <your-bot-token>
#      It'll print the chat_id; paste it below.
TELEGRAM_BOTS = {
    "pudge": {
        "token": "PASTE_BOT_TOKEN_HERE",
        "chat_id": 0,  # replace with your chat_id
    },
